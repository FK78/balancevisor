DATABASE_URL=
# Optional: Privileged connection URL for cron jobs, migrations, and admin scripts.
# This role should bypass RLS (e.g. the Postgres owner role).
# If not set, falls back to DATABASE_URL.
# DATABASE_ADMIN_URL=
# Optional: PEM-encoded CA certificate for DB SSL verification (e.g. self-signed certs).
# If not set, the system CA store is used. Only needed for non-localhost connections.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Service role key — required for admin operations like deleting user accounts (GDPR)
# Generate from Supabase Dashboard > Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set to your production URL in deployed environments (e.g. https://wealth.fahadkhan.me)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Encryption (Envelope Encryption with Per-User Keys)
# ============================================================================
#
# Master Encryption Key — used to encrypt/decrypt per-user keys stored in the
# `user_keys` table. Each user's data is encrypted with their own unique key,
# which is then encrypted with this master key.
#
# Format: 32 bytes (64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Key Rotation:
#   1. Generate a new key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   2. Set it as ENCRYPTION_KEY_V2 below
#   3. Call rotateMasterKey() from src/lib/encryption.ts
#   4. Update ENCRYPTION_KEY to the new value
#   5. Remove the old ENCRYPTION_KEY_V2 after all data is re-encrypted
ENCRYPTION_KEY=

# Optional: Next version of the master key for rotation.
# Set this BEFORE calling rotateMasterKey().
# ENCRYPTION_KEY_V2=

# Optional: Email alerts via SMTP (e.g. Stalwart, Postfix, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Wealth <alerts@yourdomain.com>

# TrueLayer Open Banking (https://truelayer.com)
# Set TRUELAYER_SANDBOX=true for sandbox mode during development
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_SANDBOX=true
# Set to true to log raw TrueLayer API responses (accounts, balances, transactions)
# DEBUG_TRUELAYER=true

# AI Financial Assistant (Groq — https://console.groq.com)
GROQ_API_KEY=

# Cron Job Secret (secures /api/cron/* endpoints)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=